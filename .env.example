# ============================================================
# CajuScript - Environment Variables
# ============================================================
# Copy this file to .env.local and fill in the values.
# Both VITE_* (Netlify/legacy) and NEXT_PUBLIC_* (Next.js) are listed.
# In code, always use NEXT_PUBLIC_* via process.env.NEXT_PUBLIC_*.
# ============================================================

# --- Site ---
NEXT_PUBLIC_SITE_URL=
VITE_PORTFOLIO_URL=

# --- Social Links ---
NEXT_PUBLIC_GITHUB_URL=
VITE_GITHUB_URL=

NEXT_PUBLIC_LINKEDIN_URL=
VITE_LINKEDIN_URL=

NEXT_PUBLIC_X_URL=
VITE_X_URL=

NEXT_PUBLIC_INSTAGRAM_URL=
VITE_INSTAGRAM_URL=

NEXT_PUBLIC_YOUTUBE_URL=
VITE_YOUTUBE_URL=

NEXT_PUBLIC_FACEBOOK_URL=
VITE_FACEBOOK_URL=

NEXT_PUBLIC_FIGMA_URL=
VITE_FIGMA_URL=

# --- Freelance Platforms ---
NEXT_PUBLIC_99FREELAS_URL=
VITE_99FREELAS_URL=

NEXT_PUBLIC_WORKANA_URL=
VITE_WORKANA_URL=

# --- Contact ---
NEXT_PUBLIC_CONTACT_EMAIL=
VITE_CONTACT_EMAIL=

# --- Analytics & Tracking ---
NEXT_PUBLIC_GA_MEASUREMENT_ID=
VITE_GA_MEASUREMENT_ID=

NEXT_PUBLIC_GTM_ID=
VITE_GTM_ID=

NEXT_PUBLIC_COUNTER_DEV_ID=
VITE_COUNTER_DEV_ID=

# --- SEO Verification ---
NEXT_PUBLIC_GOOGLE_SITE_VERIFICATION=

# --- Counter API (server-side, no prefix needed) ---
COUNTER_API_KEY=
